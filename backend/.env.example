# Supabase
SUPABASE_URL=https://yourproject.supabase.co
# Use SERVICE ROLE key here (not anon key) - bypasses RLS for backend operations
# Find it in Supabase → Settings → API → Service role key (keep this secret, never expose in frontend)
SUPABASE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# OpenAI - for embeddings
OPENAI_API_KEY=your_openai_api_key

# OpenRouter - for LLM completions
OPENROUTER_API_KEY=your_openrouter_api_key

# NewsAPI - for news ingestion
NEWSAPI_KEY=your_newsapi_key

# Resend - for email digests
RESEND_API_KEY=your_resend_api_key
DIGEST_EMAIL=your_email@example.com